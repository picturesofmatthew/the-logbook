# The Logbook — environment variables
# Copy to .env.local for development; set the same names in Vercel for production.

# The shared secret word you and Kennedy type at the door
APP_PASSCODE=

# Cookie-signing secret. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Neon Postgres connection string (added in Milestone 2)
DATABASE_URL=

# USDA FoodData Central API key (free: https://api.data.gov/signup/)
# DEMO_KEY works for development at a low rate limit. (Milestone 3)
FDC_API_KEY=DEMO_KEY
