{
  "$description": "Inklight design tokens (DTCG). The machine-readable half of ART-BIBLE.md. Feeds Style Dictionary v4 to CSS/JS now and native (Expo/RN) later. Hex color values are the pragmatic norm Style Dictionary consumes; refine to DTCG color-objects if strict conformance is needed.",
  "color": {
    "$type": "color",
    "base": {
      "cream": { "$value": "#fbf6ea", "$description": "lightest ground; never pure white" },
      "paper": { "$value": "#f5eddc", "$description": "parchment ground; the common-tier material" }
    },
    "ink": {
      "cocoa": { "$value": "#4a3b2a", "$description": "the single-weight line; never pure black" }
    },
    "flora": {
      "moss": { "$value": "#7c8a4d", "$description": "keeper A (Matthew)" },
      "pine": { "$value": "#5b6b3c" }
    },
    "ember": {
      "terracotta": { "$value": "#c4704b", "$description": "keeper B (Kennedy)" },
      "gold": { "$value": "#d9a441", "$description": "the leaf that ignites (resonant)" }
    },
    "arcane": {
      "violet": { "$value": "#8d7aa8", "$description": "union only" },
      "illumination": { "$value": "#c9b3e3", "$description": "sigil glow (legendary)" }
    },
    "glow": {
      "wick": { "$value": "#f7e3ae" }
    },
    "light": {
      "day": {
        "ground": { "$value": "#f5eddc" }
      },
      "dusk": {
        "ground": { "$value": "#ead8b4" },
        "sky": { "$value": "#6f5a78" }
      },
      "night": {
        "ground": { "$value": "#2f2820" },
        "sky": { "$value": "#453a54" }
      }
    }
  },
  "relational": {
    "$type": "color",
    "keeper-a": { "$value": "{color.flora.moss}", "$description": "Matthew — moss/green" },
    "keeper-b": { "$value": "{color.ember.terracotta}", "$description": "Kennedy — ember/terracotta" },
    "union": { "$value": "{color.arcane.violet}", "$description": "only where the two meet" }
  },
  "material": {
    "$type": "color",
    "$description": "the emblem ladder — tier -> material (see ART-BIBLE.md)",
    "open": { "$value": "{color.base.paper}", "$description": "unlit parchment; halves apart" },
    "common": { "$value": "{color.base.paper}", "$description": "matte parchment; plain closed ring" },
    "fine": { "$value": "{color.ember.gold}", "$description": "parchment + a first spark of gold" },
    "resonant": { "$value": "{color.ember.gold}", "$description": "gilt — gold-leaf illumination + violet linework" },
    "legendary": { "$value": "{color.arcane.illumination}", "$description": "lit stained glass, glowing from within" }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "draw-on": { "$value": "1200ms", "$description": "ink drawing itself onto the ring" },
      "ignite": { "$value": "600ms", "$description": "gold leaf catching along strokes" },
      "runes-cascade": { "$value": "900ms", "$description": "chord-runes lighting in sequence" },
      "union-bloom": { "$value": "800ms", "$description": "violet blooming at the union" },
      "orrery": { "$value": "4000ms", "$description": "the full ring's slow rotation" },
      "spark": { "$value": "1000ms", "$description": "ink-dot motes flying and drifting" },
      "plank": { "$value": "700ms", "$description": "the bridge plank materializing" }
    },
    "easing": {
      "$type": "cubicBezier",
      "ink": { "$value": [0.2, 0.8, 0.2, 1], "$description": "draw-on / settle" },
      "bloom": { "$value": [0.4, 0.0, 0.2, 1], "$description": "glow swelling" }
    }
  }
}
